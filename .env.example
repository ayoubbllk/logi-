# ============================================================================
# VARIABLES D'ENVIRONNEMENT — Application Contrôle Qualité
# Copier ce fichier en .env et remplir les valeurs
# ============================================================================

# ── Base de données MySQL ──
DATABASE_URL="mysql://root:password@localhost:3306/controle_qualite"
DATABASE_POOL_SIZE=10                    # Nombre de connexions dans le pool Prisma

# ── JWT ──
# IMPORTANT : Générer un secret aléatoire d'au moins 64 caractères
# Commande : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGEZ_MOI_EN_PRODUCTION_minimum_64_caracteres_de_long_pour_la_securite_du_jwt"

# ── Application ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Logging ──
LOG_LEVEL="DEBUG"                        # DEBUG | INFO | WARN | ERROR | FATAL
SLOW_QUERY_THRESHOLD=500                 # Seuil requête lente en ms

# ── Docker (utilisé dans docker-compose.yml) ──
APP_PORT=3000
DB_PORT=3306
MYSQL_ROOT_PASSWORD="root_secure_password"
MYSQL_DATABASE="controle_qualite"
MYSQL_PASSWORD="qc_secure_password"
ADMINER_PORT=8080
